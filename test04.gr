πρόγραμμα τεστ04
  δήλωση καθολικο_Α, καθολικο_Β

  διαδικασία ΑλλαξεΤιμες(παρ_τιμη, παρ_αναφορα)
    διαπροσωπεία
        είσοδος παρ_τιμη
        έξοδος παρ_αναφορα 
    δήλωση τοπικο_χ
    αρχή_διαδικασίας
        τοπικο_χ := παρ_τιμη * 2;
        παρ_αναφορα := παρ_τιμη + 5; 
        παρ_τιμη := 99;           
        γράψε(τοπικο_χ);
        γράψε(παρ_τιμη); 
        γράψε(παρ_αναφορα) 
    τέλος_διαδικασίας

    αρχή_προγράμματος
        καθολικο_Α := 10;
        καθολικο_Β := 20;
        γράψε καθολικο_Α; 
        γράψε καθολικο_Β; 

        εκτέλεσε ΑλλαξεΤιμες(καθολικο_Α, %καθολικο_Β);

        γράψε καθολικο_Α; 
        γράψε καθολικο_Β  
    τέλος_προγράμματος